{
  "name": "纹章传说",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "cf:dev": "npm run build && wrangler dev",
    "cf:types": "wrangler types",
    "cf:dry-run": "wrangler deploy --dry-run",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test:worker": "tsx --test src/worker/index.test.ts utils/apiKeyStore.test.ts utils/apiClient.test.ts utils/promptTemplates.test.ts components/ApiSettingsPanel.test.ts",
    "build": "vite build",
    "audit": "npm audit --audit-level=moderate",
    "ci": "npm run typecheck && npm run test:worker && npm run build && npm run cf:dry-run && npm run audit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "cannon-es": "^0.20.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.87.0"
  }
}
